# Ambiente
ENVIRONMENT=development
DEBUG=true

# Database
# Para Docker: postgresql+asyncpg://postgres:postgres@db:5432/mundo_invest
# Para local:  postgresql+asyncpg://postgres:postgres@localhost:5432/mundo_invest
